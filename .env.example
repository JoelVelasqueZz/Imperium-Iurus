# =============================================================================
# IMPERIUM IURIS — Variables de entorno
# Copia este archivo como .env.local y completa los valores reales.
# NUNCA subas .env.local al repositorio.
# =============================================================================

# ─── SITE ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://imperiumiuris.ec

# ─── AUTH — "Recordar este dispositivo" (2FA) ────────────────────────────────
# Secreto usado para firmar (HMAC-SHA256) el token de dispositivo confiable.
# Generar con: openssl rand -hex 32
TRUSTED_DEVICE_SECRET=

# ─── WHATSAPP BUSINESS API (Meta) ────────────────────────────────────────────
# Panel: https://developers.facebook.com/apps/
# Guía de inicio: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
#
# WHATSAPP_PHONE_NUMBER_ID     → ID del número de teléfono en Meta Business (no el número real)
# WHATSAPP_BUSINESS_ACCOUNT_ID → ID de la cuenta de WhatsApp Business
# WHATSAPP_ACCESS_TOKEN        → Token permanente (System User) o token temporal de prueba
# WHATSAPP_VERIFY_TOKEN        → String secreto que TÚ defines para verificar el webhook en Meta
# WHATSAPP_APP_SECRET          → "App Secret" de la app de Meta — firma X-Hub-Signature-256 del webhook
#
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=imperium_webhook_secret_2026
WHATSAPP_APP_SECRET=

# Número visible para usuarios (botón wa.me) — también actualizar en lib/constants.ts
NEXT_PUBLIC_WHATSAPP_NUMBER=593XXXXXXXXX

# ─── RESEND (Email transaccional) ────────────────────────────────────────────
# Panel: https://resend.com/api-keys
# Requiere dominio verificado: imperiumiuris.ec
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notificaciones@imperiumiuris.ec
RESEND_REPLY_TO=contacto@imperiumiuris.ec

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Panel: https://supabase.com/dashboard
#
# NEXT_PUBLIC_*        → Seguras para el cliente (solo lectura anon)
# SUPABASE_SERVICE_ROLE_KEY → Solo usar en el servidor — NUNCA exponer al cliente
#
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── AGENDA DE CITAS ─────────────────────────────────────────────────────────
# Opción A — Cal.com (recomendado: open source, auto-hosteable, API REST)
# Panel: https://cal.com/settings/developer/api-keys
#
CAL_API_KEY=cal_live_xxxxxxxxxxxxxxxxxxxx
# IDs de los tipos de evento configurados en Cal.com:
CAL_EVENT_TYPE_CONSULTA=      # Consulta general (30 min)
CAL_EVENT_TYPE_URGENCIA=      # Atención urgente (15 min, prioridad alta)
CAL_EVENT_TYPE_EMPRESARIAL=   # Consulta corporativa (60 min)

# Opción B — Google Calendar API (alternativa si se prefiere integración directa)
# Consola: https://console.cloud.google.com/
#
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REFRESH_TOKEN=
# GOOGLE_CALENDAR_CALENDAR_ID=xxx@group.calendar.google.com

# ─── NOTAS DE CONFIGURACIÓN ──────────────────────────────────────────────────
# 1. Actualizar lib/constants.ts con los números de teléfono reales
#    CONTACT.phone    → '+593 9X XXX XXXX'
#    CONTACT.whatsapp → '+593 9X XXX XXXX'
#
# 2. El webhook de WhatsApp debe estar en HTTPS con certificado válido.
#    URL del webhook: https://imperiumiuris.ec/api/whatsapp/webhook
#
# 3. Supabase: ejecutar las migraciones de schema antes de activar los endpoints.
#    Tablas necesarias: consultas, citas, clientes
